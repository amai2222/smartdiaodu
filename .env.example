# 复制为 .env 并填入真实值，勿提交 .env（.env 已在 .gitignore）
# 后端用此连接 Supabase 并读取 app_config，除这两项外其余配置从数据库读
SUPABASE_URL=https://zqcctbcwibnqmumtqweu.supabase.co
SUPABASE_SERVICE_ROLE_KEY=在这里粘贴_Dashboard_Settings_API_里的_service_role_密钥

# ---------- 探子脚本（probe/tanzi.py、navigate_helo.py）----------
# 探子从本文件同目录的 .env 读取（运行前请从项目根目录执行或确保 load_dotenv 已加载根目录 .env）
# 上面 SUPABASE_URL、SUPABASE_SERVICE_ROLE_KEY 与大脑共用，探子用其直接读 driver_state.current_loc 等
# 可选：指定司机 ID，不填则探子用脚本内默认
# TANZI_DRIVER_ID=a0000001-0000-4000-8000-000000000001
# 可选：探子专用测试用司机位置（未配置 Supabase 时可设此项测试「改出发地」流程）
# TANZI_DRIVER_LOC=如东县委党校
# TANZI_DRIVER_DEST=上海市外滩（navigate_helo 同步目的地时，无数据库则用此值）
# TANZI_DRIVER_DEPART_TIME=明天 08:00（出现「请选择预计出发时间」时用此值选日期时间，如 明天 8点00分、08:00）
# 可选：探子连接设备号（adb devices 看到的序列号）
# TANZI_DEVICE=RF8M13AM0LZ
# 可选：大脑 API 根地址（与 web/config 一致）
# TANZI_API_BASE=https://xg.325218.xyz/api

# ---------- 可选：其他 ----------
# 邮箱登录后换大脑 JWT 时验证 Supabase token（Supabase → JWT Keys → Legacy JWT secret → Reveal 复制）
# SUPABASE_JWT_SECRET=你的_Legacy_JWT_Secret
# JWT 登录签发密钥
# JWT_SECRET=随机字符串
