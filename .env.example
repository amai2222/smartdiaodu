# 复制为 .env 并填入真实值，勿提交 .env（.env 已在 .gitignore）
# 后端用此连接 Supabase 并读取 app_config，除这两项外其余配置从数据库读
SUPABASE_URL=https://zqcctbcwibnqmumtqweu.supabase.co
SUPABASE_SERVICE_ROLE_KEY=在这里粘贴_Dashboard_Settings_API_里的_service_role_密钥
